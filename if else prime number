// problem 7
// prime number check true and false

#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    bool isPrime = true;   // better to use bool

    if (n < 2) {
        isPrime = false;   // fixed variable name
    } else {
        for (int i = 2; i < n; i++) {
            if (n % i == 0) {
                isPrime = false;
                break;
            }
        }
    }

    if (isPrime) {
        cout << "It is a prime number...";
    } else {
        cout << "It is not a prime number";
    }

    return 0;
}
